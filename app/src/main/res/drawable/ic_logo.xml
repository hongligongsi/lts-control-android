<?xml version="1.0" encoding="utf-8"?>
<!--
  LTS Respooler Pro logo
  - Black center disc (spool hub / main shaft)
  - Two 180°-symmetric blue arcs (paired cooling / exhaust fans, viewed top-down)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="120">

    <!-- Upper blue arc (cooling fan) -->
    <path
        android:fillColor="#1E88E5"
        android:pathData="M60,8
                          C 82,8 92,30 88,52
                          C 76,52 64,40 64,28
                          C 64,20 60,8 60,8 Z" />

    <!-- Lower blue arc (exhaust fan, 180° rotation) -->
    <path
        android:fillColor="#1E88E5"
        android:pathData="M60,112
                          C 38,112 28,90 32,68
                          C 44,68 56,80 56,92
                          C 56,100 60,112 60,112 Z" />

    <!-- Center black disc -->
    <path
        android:fillColor="#0A0A0A"
        android:pathData="M60,60
                          m -18,0
                          a 18,18 0 1,0 36,0
                          a 18,18 0 1,0 -36,0 Z" />

    <!-- Center inner highlight (subtle, gives depth) -->
    <path
        android:fillColor="#1A1A1A"
        android:pathData="M60,60
                          m -8,0
                          a 8,8 0 1,0 16,0
                          a 8,8 0 1,0 -16,0 Z" />
</vector>
